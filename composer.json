{
    "name": "sunnysideup/core-modules-dev",
    "description": "Nice modules to include on your dev install.",
    "type": "silverstripe-recipe",
    "keywords": [
        "dev",
        "developer tools"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "phpunit/phpunit": "^9.6",
        "sunnysideup/sswebpack_engine_only": "dev-main",
        "silverleague/ideannotator": "^4",
        "sunnysideup/delete-members": "dev-main",
        "sunnysideup/vardump": "dev-main",
        "sunnysideup/templateoverview": "dev-main",
        "sunnysideup/typography": "dev-main",
        "sunnysideup/cleanup-tables": "dev-main",
        "sunnysideup/gitignore": "dev-main",
        "sunnysideup/spring-clean-recipe": "dev-main",
        "roave/security-advisories": "*"
    },
    "autoload": {
        "psr-4": {
            "Sunnysideup\\CoreModulesDev\\": "src/"
        }
    },
    "suggests": {
        "silverstripe/standards": "Great, but phpstan/phpstan causes issues!"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Nicolaas Thiemen Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ],
    "bin": [
        "bin/compress-and-anonymise-database"
    ]
}
